class MembraneBuilderSocketError extends Error {
    constructor(public socketEvent:string, public message:string) {
        super();   
    }
}

export class MembraneBuilderSocketManager {

    // Wrapping in class so that function oisting is correct for future decorator additions.
    static socket: Socket;

    static bind(socket: Socket) {
        MembraneBuilderSocketManager.socket = socket;
     
        socket.on("membraneBuilderSubmit", MembraneBuilderSocketManager.InsaneInput);

  
        logger.debug("[MembraneBuilderSocketManager] Bound");
    }

    static wrapper (, ...args:any[])
    static error(name:string, d:Record<string, string|number|boolean>) {
        MembraneBuilderSocketManager.socket.emit(name, d); // some typings ?
    }

    //@processData
    static async InsaneInput(data: any) {
        logger.debug("[SOCKET:MembraneBuilder] Event:membraneBuilderSubmit");
        logger.debug(inspect(data)); //<-- itp name somewhere ?
        let inputs;

        logger.debug("Running Socket TESTING ERROR BUBBLE");
        throw new MembraneBuilderSocketError("dummy_error", "titi toto");
/*
        try {
            const {parameters, pdb, top, itps} = processData(data);
            logger.debug("[SOCKET:MembraneBuilder] Let's go");
            await validateOrReject(parameters);
            await validateOrReject(pdb); // seems trashy, consuming Buffer ?
            await validateOrReject(top);
            await Promise.all(itps.map((dto:any) => validateOrReject(dto)))
            inputs = {parameters, pdb, top, itps};
        } catch (e) {
            logger.debug("[SOCKET:MembraneBuilder] emitin error on socket");
            MembraneBuilderSocketManager.error("InsaneInputValidationError",
                        { error: true, type: 'PARAMS_VALIDATION_ERROR', message:e instanceof(Error)? e.message :'' });
            return;
        }

       
        
        MembraneBuilderSocketManager.insaneProcess(inputs);
        */
    }

    static async insaneProcess({ pdb, top, itps, parameters }:InsaneSettings) {
        logger.debug("Running Socket INSANE PLACEHOLDER");
        
        const molecule_inputs: MembraneRunnerMolInputs = {};
        molecule_inputs.pdb = {
            originalName: pdb.originalname,
            //@ts-ignore
            content: InputTextWrapper(validatedPdb.path)
        }
        molecule_inputs.top = {
            originalName: top.originalname,
            //@ts-ignore
            content: InputTextWrapper(validatedTop.path)
        }
        molecule_inputs.itps = itps.map((itp) => {
            return {
                originalName: itp.originalname,
                //@ts-ignore
                content: InputTextWrapper(itp.path)
            }});
        

        try {
            const data = await membraneBuilderRunner(molecule_inputs, parameters);
            logger.debug("[SOCKET:MembraneBuilder:insaneProcess] SUCCESSFULL");
            //res.json(data);
            
          } catch(e){
            if (e instanceof InsaneMissingParameterError) 
                throw new MembraneBuilderSocketError("InsaneMissingParameterError", e.message);
            else 
                throw("TITIORO")
          }
    }
}

